# =============================================================================
# auth-service (Cloudflare Worker) configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in every value. `.env` is gitignored.
#   • Local dev  → `npm run dev` copies .env → .dev.vars for `wrangler dev`.
#   • Production → `npm run deploy:secrets` uploads every value as a Cloudflare
#                  secret (run once after `npm run deploy`).
# See /SETUP.md for a step-by-step walkthrough of obtaining each credential.
# Generate the random secrets (JWT_SECRET, OTP_PEPPER, BOOTSTRAP_SECRET) with:
#   openssl rand -hex 32
# =============================================================================

# --- 1. Shop identity ---------------------------------------------------------
# SHOP_CODE: stable slug identifying this tenant's data. All data lives under
#   shops/<SHOP_CODE>/... in both Firestore and Supabase. Must match the shop
#   code entered in the mobile app and web-portal Settings. Keep it hard to
#   guess (e.g. append random hex): my-shop-4f9c2a1b
SHOP_CODE=your-shop-code
# SHOP_NAME: human-readable display name. Shown in OTP emails, admin alerts,
#   and as the default brand name. Replaces any hardcoded brand.
SHOP_NAME=Your Shop

# --- 2. Supabase (auth DB + Firestore read-replica) ---------------------------
# Create a free project at https://supabase.com/dashboard. Then:
#   Dashboard → Project Settings → API
# SUPABASE_URL:         "Project URL"        (https://<ref>.supabase.co)
# SUPABASE_SERVICE_KEY: "service_role" key   (SECRET — bypasses RLS, full DB)
# SUPABASE_ANON_KEY:    "anon public" key    (publishable; handed to mobile)
# SUPABASE_JWT_SECRET:  Settings → API → "JWT Secret" (mints Realtime tokens)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- 3. Email provider (OTP + statements) -------------------------------------
# EMAIL_PROVIDER: "brevo" (recommended, 300/day free, no domain needed) or
#   "resend" (100/day, requires domain verification for arbitrary recipients).
EMAIL_PROVIDER=brevo
EMAIL_FROM=noreply@yourshop.example
EMAIL_FROM_NAME=Your Shop
# Brevo: https://app.brevo.com → SMTP & API → API Keys → Create a new API key
BREVO_API_KEY=your-brevo-api-key
# Resend (only if EMAIL_PROVIDER=resend): https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=
RESEND_FROM_NAME=

# --- 4. App secrets (generate with: openssl rand -hex 32) ---------------------
# JWT_SECRET:      signs portal/client session tokens
# OTP_PEPPER:      server-only pepper mixed into OTP hashes
# BOOTSTRAP_SECRET: guards POST /admin/bootstrap (first-admin creation)
JWT_SECRET=your-random-64-char-hex
OTP_PEPPER=your-random-64-char-hex
BOOTSTRAP_SECRET=your-random-64-char-hex

# --- 5. First admin (created by `npm run bootstrap`) --------------------------
ADMIN_EMAIL=admin@yourshop.example
ADMIN_NAME=Admin

# --- 6. Firebase service account (cron reads Firestore via REST) --------------
# Firebase Console → Project Settings → Service accounts → Generate new private
# key. From the downloaded JSON copy:
#   FIREBASE_PROJECT_ID   → "project_id"
#   FIREBASE_CLIENT_EMAIL → "client_email"
#   FIREBASE_PRIVATE_KEY  → "private_key" — keep the literal \n escapes, wrap in
#                           double quotes on a single line (the worker re-expands
#                           \n to real newlines before signing).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- 7. CORS & portal ---------------------------------------------------------
# Comma-separated allowed origins: your portal URL + localhost + capacitor.
ALLOWED_ORIGINS=https://portal.yourshop.example,http://localhost:3000,http://localhost:5173,http://localhost,capacitor://localhost,https://localhost
# PORTAL_URL: base URL of your deployed web-portal. Used only to build the
# "View logs" link in worker alert emails. Optional — leave blank to omit.
PORTAL_URL=https://portal.yourshop.example

# --- 8. Optional: usage dashboards (admin → Usage) ----------------------------
# Cloudflare token: dash.cloudflare.com/profile/api-tokens, scope Account →
#   Analytics → Read. Account id is on any zone's overview page.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ANALYTICS_TOKEN=
# Cloudinary (image hosting + usage stats): cloudinary.com → Console → Account
#   Details. Cloud name is public; API key/secret are for usage stats only.
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- 9. Optional tuning -------------------------------------------------------
# These are NON-SECRET. Their production values live in wrangler.toml [vars];
# the entries below only affect LOCAL dev (via .dev.vars). To change them in
# production, edit wrangler.toml [vars] and redeploy — do NOT add them as secrets
# (that would collide with [vars]). Leave as-is unless you have a reason.
OTP_TTL_MINUTES=10
JWT_TTL_MINUTES=720
JWT_TTL_CLIENT_MINUTES=43200
RATE_LIMIT_PER_IDENTIFIER_PER_HOUR=10
RATE_LIMIT_PER_IP_PER_HOUR=30
RATE_LIMIT_VERIFY_ATTEMPTS=5
