# Mobile app build-time env. Copy to `.env.local` (dev) / `.env.production` (build).
# Both are gitignored.

# Base URL of your deployed auth-service Cloudflare Worker.
# After you deploy auth-service (see /SETUP.md), use its URL, e.g.
#   https://billmaker-auth.<your-cf-subdomain>.workers.dev
# or a custom domain like https://auth.yourshop.example
# For local dev against a locally-running worker, use http://localhost:8787
VITE_AUTH_SERVICE_URL=https://auth.yourshop.example
