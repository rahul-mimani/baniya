# product-enrich — local product enrichment tool config
# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# The shop code whose portal_products you want to enrich.
# This is the same shop code you set up in the app (see /SETUP.md).
SHOP_CODE=your-shop-code

# Tavily Search API key — used to fetch product descriptions & images.
# Get a free key (1000 searches/mo) at https://app.tavily.com/ → API Keys.
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the local enrichment UI/server listens on.
PORT=3000

# NOTE: this tool also needs a Firebase service-account key at ./prod.json
# (gitignored). See /SETUP.md → "Firebase service account" for how to create one.
