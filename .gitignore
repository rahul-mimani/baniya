# Root .gitignore — belt-and-suspenders over per-project ignores.

# Dependencies / build output
node_modules/
dist/
build/

# Env & secrets (never commit real values — *.example templates are committed)
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
!.dev.vars.example
*-firebase-sa.json
*-sa.json
service-account*.json
firebase-adminsdk*.json
prod.json
.firebaserc

# Logs & OS/editor artifacts
*.log
.DS_Store
.idea/
*.swp
*.swo

# Generated APKs
*.apk
